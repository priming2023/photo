# Fal.ai — AI 사진 변환 API 키
# https://fal.ai → Keys
VITE_FAL_KEY=your_fal_api_key

# Supabase — 사진 업로드 & QR 공유
# https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# QR 링크용 공개 앱 URL (키오스크/배포 도메인)
# Vercel: https://phto-orcin.vercel.app
VITE_PUBLIC_APP_URL=https://phto-orcin.vercel.app

# Electron 영수증 프린터 이름 (Windows 장치 관리자에서 확인)
# 예: EPSON TM-T20, Star TSP143
PRINTER_NAME=
