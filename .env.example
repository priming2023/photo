# Fal.ai — AI 사진 변환 API 키
# https://fal.ai → Keys
VITE_FAL_KEY=your_fal_api_key

# Supabase — 사진 업로드 & QR 공유
# https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# QR 링크용 공개 앱 URL (키오스크/배포 도메인)
VITE_PUBLIC_APP_URL=https://phto-orcin.vercel.app

# Electron 전용 (선택)
# ELECTRON_APP_URL=https://phto-orcin.vercel.app   # Electron이 로드할 웹앱 URL (기본: VITE_PUBLIC_APP_URL)
# ELECTRON_USE_LOCAL=true                          # true면 dist/ 로컬 빌드 사용 (오프라인 테스트용)

# 매장 브랜딩 (다른 지점 확장 시 변경)
VITE_STORE_NAME=월드킹 당진서산점
VITE_STORE_BRANCH=당진서산점
VITE_STORE_ADDRESS=충남 당진시
VITE_STORE_PHONE=

# Sentry 에러 모니터링 (선택 — 없으면 비활성)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Electron 영수증 프린터 이름 (Windows 장치 관리자에서 확인)
PRINTER_NAME=
